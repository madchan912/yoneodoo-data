# ---------------------------------------------------------------------------
# 요너두 데이터 파이프라인 v2.0 — 환경변수
# ---------------------------------------------------------------------------
# 사용법: 이 파일을 복사해 `.env` 로 저장한 뒤 값을 수정하세요.

# yoneodoo-api 레시피 엔드포인트 (로컬 Spring Boot)
API_BASE_URL=http://localhost:8080/api/v1/recipes
# 운영 서버
# API_BASE_URL=https://yoneodoo.com/api/v1/recipes

# Gemini API 키 (Google AI Studio에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here

# Discord 웹훅 URL (배치 알림용, 선택사항)
DISCORD_WEBHOOK_URL=
