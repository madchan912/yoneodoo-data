# ---------------------------------------------------------------------------
# 요너두 데이터 파이프라인 — 백엔드 레시피 API
# ---------------------------------------------------------------------------
# 사용법: 이 파일을 복사해 `.env` 로 저장한 뒤 값을 수정하세요.
#         (`python-dotenv` 가 프로젝트 루트의 .env 를 읽습니다.)
#
# 로컬 Spring Boot — 레시피 엔드포인트 전체 경로
API_BASE_URL=http://localhost:8080/api/v1/recipes

# 운영(Render 등)으로 적재할 때 예시
# API_BASE_URL=https://yoneodoo-api.onrender.com/api/v1/recipes
